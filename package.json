{
  "name": "youtube-downloader-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Modern YouTube downloader desktop app built with Vite and Tauri",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:functions\" \"npm:dev:web\"",
    "dev:functions": "firebase emulators:start --only functions",
    "dev:web": "vite",
    "build": "vite build",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "serve": "firebase emulators:start",
    "deploy": "firebase deploy",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "concurrently": "^9.2.1",
    "firebase-tools": "^15.8.0",
    "pngjs": "^7.0.0",
    "vite": "^7.1.5"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0"
  }
}
